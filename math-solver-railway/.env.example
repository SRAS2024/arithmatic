# Arithmetic Math Solver - Environment Variables
# Copy this file to .env and fill in values

# Meteor Configuration
PORT=3000
ROOT_URL=http://localhost:3000
MONGO_URL=mongodb://localhost:27017/arithmetic

# Python Service
PYTHON_SERVICE_URL=http://localhost:5000
PYTHON_VENV_PATH=./python/venv

# Upload Limits
MAX_UPLOAD_SIZE=20971520
TEMP_DIR=./server/temp
CLEANUP_INTERVAL=3600000

# Feature Flags
ENABLE_OCR=true
ENABLE_HANDWRITING=true
ENABLE_GRAPHING=true
ENABLE_PDF_PROCESSING=true
ENABLE_REPORT_GENERATION=true

# Optional API Keys (system works without these)
OPENAI_API_KEY=
WOLFRAM_APP_ID=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Timeouts (milliseconds)
SOLVE_TIMEOUT=30000
OCR_TIMEOUT=60000
PDF_TIMEOUT=120000
GRAPH_TIMEOUT=15000
REPORT_TIMEOUT=30000
